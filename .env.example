# GrooveBox v2.2 - Configurazione ambiente
# Copia questo file in .env e adatta i valori al tuo hardware

# Directory dove vengono salvate le registrazioni
RECORDINGS_DIR=/mnt/groovebox/Registrazioni

# Dispositivo di uscita ALSA per cuffie/jack
PLAYBACK_CARD=plughw:CARD=Headphones,DEV=0

# Parametri audio
SAMPLE_RATE=96000
CHANNELS=2
BIT_DEPTH=S24_3LE

# Secondi di avanzamento/rewind rapido
FF_RW_SECONDS=10

# PipeWire: nome del nodo sorgente (preamplificatore phono USB)
PW_SOURCE=alsa_input.usb-Terratec_PhonoPreAmp_iVinyl-00.analog-stereo

# PipeWire: sink uscita audio integrata Pi
PW_SINK=alsa_output.platform-fe00b840.mailbox.stereo-fallback

# Porta HTTP del server
PORT=5000
